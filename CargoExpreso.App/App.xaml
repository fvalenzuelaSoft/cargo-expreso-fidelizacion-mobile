<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:CargoExpreso.App.Converters"
             x:Class="CargoExpreso.App.App">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters available app-wide -->
            <conv:InvertBoolConverter              x:Key="InvertBoolConverter"/>
            <conv:NotEmptyConverter                x:Key="NotEmptyConverter"/>
            <conv:Base64ToImageSourceConverter     x:Key="Base64ToImageSourceConverter"/>
            <conv:TransactionTypeToColorConverter  x:Key="TransactionTypeToColorConverter"/>
            <conv:TransactionTypeToIconConverter   x:Key="TransactionTypeToIconConverter"/>
        </ResourceDictionary>
    </Application.Resources>

</Application>
